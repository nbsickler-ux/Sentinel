# ============================================================
# Market Intelligence Agent — Environment Variables
# Copy to ../.env (project root) and fill in values.
# ============================================================

# --- Required ---

# Postgres connection string (Render / Neon / local)
DATABASE_URL=postgresql://user:pass@host:5432/sentinel

# Upstash Redis REST (shared with Sentinel)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Alchemy — Base mainnet RPC (shared with Sentinel)
ALCHEMY_API_KEY=your-alchemy-key

# --- Data Sources (at least one recommended) ---

# Coinbase Advanced Trade API (cbBTC CEX prices)
COINBASE_ADV_API_KEY=
COINBASE_ADV_API_SECRET=

# CoinGecko (free tier OK for Phase 1)
COINGECKO_API_KEY=

# FRED (macro indicators — free key from fred.stlouisfed.org)
FRED_API_KEY=

# NewsAPI.org (crypto news ingestion)
NEWS_API_KEY=

# Benzinga (alternative news source)
BENZINGA_API_KEY=

# The Graph (Aerodrome subgraph — DEX pool data)
THE_GRAPH_API_KEY=

# --- Qualitative Analysis ---

# Anthropic Claude API (qualitative module)
ANTHROPIC_API_KEY=

# --- Server ---

# Port for Express server (default: 4030)
MARKET_AGENT_PORT=4030

# API auth key (optional — if set, all non-health endpoints require Bearer token)
MARKET_AGENT_API_KEY=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Environment: development | production
NODE_ENV=development
