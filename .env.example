# ============================================================
# Sentinel — Environment Configuration
# ============================================================
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# Your USDC receiving wallet address on Base
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Network: "base-sepolia" for testing, "base" for production
NETWORK=base-sepolia

# x402 Facilitator
# Testnet fallback: https://x402.org/facilitator
# Production (Base mainnet): uses CDP facilitator via @coinbase/x402
# Set CDP_API_KEY_ID + CDP_API_KEY_SECRET below to enable CDP facilitator
FACILITATOR_URL=https://x402.org/facilitator

# Alchemy API Key (free tier works)
# https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_key

# Etherscan V2 API Key (works across all chains including Base)
# https://etherscan.io/apis
# Note: env var kept as BASESCAN_API_KEY for backward compatibility
BASESCAN_API_KEY=your_etherscan_v2_key

# GoPlus Security API (free tier with API key)
# Register at https://console.gopluslabs.io to get key + secret
GOPLUS_API_KEY=your_goplus_key
GOPLUS_API_SECRET=your_goplus_secret

# Coinbase Developer Platform (for AgentKit / wallet features)
CDP_API_KEY_ID=your_cdp_key_id
CDP_API_KEY_SECRET=your_cdp_key_secret

# Upstash Redis (caching, reputation tracking, rate limiting)
# https://console.upstash.com/ — create a Redis database, copy REST URL + token
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# EAS Attestations (on-chain trust records on Base)
# SENTINEL_DEPLOYER_KEY: private key for signing attestation transactions
# EAS_SCHEMA_UID: run `node lib/eas/deploy-schema.js` to register and get the UID
SENTINEL_DEPLOYER_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
EAS_SCHEMA_UID=0xYOUR_SCHEMA_UID_FROM_DEPLOY_SCRIPT

# PostgreSQL (compliance audit trail, daily reports)
# Provide a full connection string. Render/Supabase/Neon all work.
DATABASE_URL=postgresql://user:password@host:5432/sentinel

# Admin endpoint
# Set this to enable GET /admin/stats for traffic monitoring
SENTINEL_ADMIN_KEY=your_admin_secret

# Server
PORT=4021
LOG_LEVEL=info
